import 'package:flutter/material.dart';
import 'package:shared_preferences/shared_preferences.dart';
import 'dart:convert';

void main() async {
  WidgetsFlutterBinding.ensureInitialized();
  runApp(const CalendarApp());
}

// ─── Event Types ────────────────────────────────────────────────────────────

enum EventType {
  trip,
  meeting,
  run,
  birthday,
  date,
  school,
  other,
}

extension EventTypeExtension on EventType {
  String label(bool isRu) {
    switch (this) {
      case EventType.trip:
        return isRu ? 'Поездка' : 'Trip';
      case EventType.meeting:
        return isRu ? 'Встреча' : 'Meeting';
      case EventType.run:
        return isRu ? 'Пробежка' : 'Run';
      case EventType.birthday:
        return isRu ? 'День рождения' : 'Birthday';
      case EventType.date:
        return isRu ? 'Свидание' : 'Date';
      case EventType.school:
        return isRu ? 'Школа' : 'School';
      case EventType.other:
        return isRu ? 'Другое' : 'Other';
    }
  }

  String get emoji {
    switch (this) {
      case EventType.trip:
        return '✈️';
      case EventType.meeting:
        return '🤝';
      case EventType.run:
        return '🏃';
      case EventType.birthday:
        return '🎂';
      case EventType.date:
        return '❤️';
      case EventType.school:
        return '🎓';
      case EventType.other:
        return '📌';
    }
  }

  Color get color {
    switch (this) {
      case EventType.trip:
        return const Color(0xFF5B9BD5);
      case EventType.meeting:
        return const Color(0xFF70B8A0);
      case EventType.run:
        return const Color(0xFFE07B5F);
      case EventType.birthday:
        return const Color(0xFFD4A0D0);
      case EventType.date:
        return const Color(0xFFE87070);
      case EventType.school:
        return const Color(0xFFE8C160);
      case EventType.other:
        return const Color(0xFF9E9E9E);
    }
  }
}

// ─── App State ──────────────────────────────────────────────────────────────

class AppState extends ChangeNotifier {
  bool _isDark = false;
  bool _isRu = true;
  // key: "yyyy-MM-dd", value: list of EventType names
  Map<String, List<String>> _events = {};

  bool get isDark => _isDark;
  bool get isRu => _isRu;
  Map<String, List<String>> get events => _events;

  Future<void> load() async {
    final prefs = await SharedPreferences.getInstance();
    _isDark = prefs.getBool('isDark') ?? false;
    _isRu = prefs.getBool('isRu') ?? true;
    final raw = prefs.getString('events');
    if (raw != null) {
      final decoded = jsonDecode(raw) as Map<String, dynamic>;
      _events = decoded.map((k, v) =>
          MapEntry(k, List<String>.from(v as List)));
    }
    notifyListeners();
  }

  Future<void> toggleTheme() async {
    _isDark = !_isDark;
    final prefs = await SharedPreferences.getInstance();
    await prefs.setBool('isDark', _isDark);
    notifyListeners();
  }

  Future<void> toggleLanguage() async {
    _isRu = !_isRu;
    final prefs = await SharedPreferences.getInstance();
    await prefs.setBool('isRu', _isRu);
    notifyListeners();
  }

  Future<void> setEventsForDay(String dateKey, List<EventType> types) async {
    _events[dateKey] = types.map((t) => t.name).toList();
    final prefs = await SharedPreferences.getInstance();
    await prefs.setString('events', jsonEncode(_events));
    notifyListeners();
  }

  List<EventType> getEventsForDay(String dateKey) {
    final list = _events[dateKey];
    if (list == null) return [];
    return list
        .map((name) => EventType.values.firstWhere(
              (e) => e.name == name,
              orElse: () => EventType.other,
            ))
        .toList();
  }
}

// ─── Main App ───────────────────────────────────────────────────────────────

class CalendarApp extends StatefulWidget {
  const CalendarApp({super.key});

  @override
  State<CalendarApp> createState() => _CalendarAppState();
}

class _CalendarAppState extends State<CalendarApp> {
  final AppState _appState = AppState();
  bool _loaded = false;

  @override
  void initState() {
    super.initState();
    _appState.load().then((_) => setState(() => _loaded = true));
  }

  @override
  Widget build(BuildContext context) {
    if (!_loaded) {
      return const MaterialApp(
        home: Scaffold(body: Center(child: CircularProgressIndicator())),
      );
    }
    return AnimatedBuilder(
      animation: _appState,
      builder: (context, _) {
        return MaterialApp(
          debugShowCheckedModeBanner: false,
          theme: _appState.isDark ? _darkTheme() : _lightTheme(),
          home: CalendarHome(appState: _appState),
        );
      },
    );
  }

  ThemeData _lightTheme() => ThemeData(
        brightness: Brightness.light,
        scaffoldBackgroundColor: const Color(0xFFF2F4F8),
        colorScheme: ColorScheme.light(
          primary: const Color(0xFF5A8FDB),
          surface: Colors.white,
        ),
        fontFamily: 'Roboto',
      );

  ThemeData _darkTheme() => ThemeData(
        brightness: Brightness.dark,
        scaffoldBackgroundColor: const Color(0xFF1A1D2E),
        colorScheme: ColorScheme.dark(
          primary: const Color(0xFF5A8FDB),
          surface: const Color(0xFF252840),
        ),
        fontFamily: 'Roboto',
      );
}

// ─── Calendar Home ──────────────────────────────────────────────────────────

class CalendarHome extends StatefulWidget {
  final AppState appState;
  const CalendarHome({super.key, required this.appState});

  @override
  State<CalendarHome> createState() => _CalendarHomeState();
}

class _CalendarHomeState extends State<CalendarHome> {
  late DateTime _currentMonth;
  DateTime? _selectedDay;

  @override
  void initState() {
    super.initState();
    _currentMonth = DateTime(DateTime.now().year, DateTime.now().month);
    _selectedDay = DateTime.now();
  }

  AppState get state => widget.appState;

  String _dateKey(DateTime d) =>
      '${d.year}-${d.month.toString().padLeft(2, '0')}-${d.day.toString().padLeft(2, '0')}';

  void _prevMonth() =>
      setState(() => _currentMonth =
          DateTime(_currentMonth.year, _currentMonth.month - 1));

  void _nextMonth() =>
      setState(() => _currentMonth =
          DateTime(_currentMonth.year, _currentMonth.month + 1));

  String _monthLabel() {
    const ruMonths = [
      'Январь', 'Февраль', 'Март', 'Апрель', 'Май', 'Июнь',
      'Июль', 'Август', 'Сентябрь', 'Октябрь', 'Ноябрь', 'Декабрь'
    ];
    const enMonths = [
      'January', 'February', 'March', 'April', 'May', 'June',
      'July', 'August', 'September', 'October', 'November', 'December'
    ];
    final months = state.isRu ? ruMonths : enMonths;
    return '${months[_currentMonth.month - 1]} ${_currentMonth.year}';
  }

  List<String> _weekdayLabels() =>
      state.isRu
          ? ['Вс', 'Пн', 'Вт', 'Ср', 'Чт', 'Пт', 'Сб']
          : ['Su', 'Mo', 'Tu', 'We', 'Th', 'Fr', 'Sa'];

  @override
  Widget build(BuildContext context) {
    final isDark = state.isDark;
    final bgColor = isDark ? const Color(0xFF1A1D2E) : const Color(0xFFF2F4F8);
    final cardColor = isDark ? const Color(0xFF252840) : Colors.white;
    final textColor = isDark ? Colors.white : const Color(0xFF1A1D2E);
    final subColor = isDark ? const Color(0xFF8890AA) : const Color(0xFF8890AA);

    return AnimatedBuilder(
      animation: state,
      builder: (context, _) {
        return Scaffold(
          backgroundColor: bgColor,
          body: SafeArea(
            child: Column(
              children: [
                // ── Header ─────────────────────────────────────────────
                Padding(
                  padding:
                      const EdgeInsets.symmetric(horizontal: 20, vertical: 16),
                  child: Row(
                    children: [
                      Text(
                        state.isRu ? 'Календарь' : 'Calendar',
                        style: TextStyle(
                          fontSize: 26,
                          fontWeight: FontWeight.w700,
                          color: textColor,
                        ),
                      ),
                      const Spacer(),
                      _MenuButton(appState: state),
                    ],
                  ),
                ),

                // ── Month nav ──────────────────────────────────────────
                Padding(
                  padding: const EdgeInsets.symmetric(horizontal: 20),
                  child: Row(
                    children: [
                      _NavArrow(
                          icon: Icons.chevron_left,
                          onTap: _prevMonth,
                          isDark: isDark),
                      const SizedBox(width: 12),
                      Text(
                        _monthLabel(),
                        style: TextStyle(
                          fontSize: 17,
                          fontWeight: FontWeight.w600,
                          color: textColor,
                        ),
                      ),
                      const SizedBox(width: 12),
                      _NavArrow(
                          icon: Icons.chevron_right,
                          onTap: _nextMonth,
                          isDark: isDark),
                    ],
                  ),
                ),
                const SizedBox(height: 16),

                // ── Calendar card ─────────────────────────────────────
                Padding(
                  padding: const EdgeInsets.symmetric(horizontal: 16),
                  child: Container(
                    decoration: BoxDecoration(
                      color: cardColor,
                      borderRadius: BorderRadius.circular(24),
                      boxShadow: [
                        BoxShadow(
                          color: Colors.black
                              .withOpacity(isDark ? 0.3 : 0.06),
                          blurRadius: 20,
                          offset: const Offset(0, 4),
                        ),
                      ],
                    ),
                    child: Padding(
                      padding: const EdgeInsets.all(16),
                      child: _CalendarGrid(
                        currentMonth: _currentMonth,
                        selectedDay: _selectedDay,
                        weekdayLabels: _weekdayLabels(),
                        appState: state,
                        onDayTap: (day) {
                          setState(() => _selectedDay = day);
                          _showEventPicker(day);
                        },
                        isDark: isDark,
                      ),
                    ),
                  ),
                ),
                const SizedBox(height: 20),

                // ── Selected day events ──────────────────────────────
                if (_selectedDay != null)
                  _DayEventSummary(
                    day: _selectedDay!,
                    appState: state,
                    cardColor: cardColor,
                    textColor: textColor,
                    subColor: subColor,
                  ),
              ],
            ),
          ),
        );
      },
    );
  }

  void _showEventPicker(DateTime day) {
    showModalBottomSheet(
      context: context,
      backgroundColor: Colors.transparent,
      isScrollControlled: true,
      builder: (_) => _EventPickerSheet(
        day: day,
        appState: state,
        onSave: (types) async {
          await state.setEventsForDay(_dateKey(day), types);
          setState(() {});
        },
      ),
    );
  }
}

// ─── Calendar Grid ───────────────────────────────────────────────────────────

class _CalendarGrid extends StatelessWidget {
  final DateTime currentMonth;
  final DateTime? selectedDay;
  final List<String> weekdayLabels;
  final AppState appState;
  final void Function(DateTime) onDayTap;
  final bool isDark;

  const _CalendarGrid({
    required this.currentMonth,
    required this.selectedDay,
    required this.weekdayLabels,
    required this.appState,
    required this.onDayTap,
    required this.isDark,
  });

  String _dateKey(DateTime d) =>
      '${d.year}-${d.month.toString().padLeft(2, '0')}-${d.day.toString().padLeft(2, '0')}';

  @override
  Widget build(BuildContext context) {
    final firstDay = DateTime(currentMonth.year, currentMonth.month, 1);
    final lastDay = DateTime(currentMonth.year, currentMonth.month + 1, 0);
    final startOffset = firstDay.weekday % 7; // Sunday=0

    final cells = <DateTime?>[];
    for (int i = 0; i < startOffset; i++) cells.add(null);
    for (int d = 1; d <= lastDay.day; d++) {
      cells.add(DateTime(currentMonth.year, currentMonth.month, d));
    }
    while (cells.length % 7 != 0) cells.add(null);

    final labelColor = isDark ? const Color(0xFF8890AA) : const Color(0xFF9DA3B4);

    return Column(
      children: [
        // Weekday headers
        Row(
          children: weekdayLabels.asMap().entries.map((e) {
            final i = e.key;
            final label = e.value;
            final isWeekend = i == 0 || i == 6;
            return Expanded(
              child: Center(
                child: Text(
                  label,
                  style: TextStyle(
                    fontSize: 13,
                    fontWeight: FontWeight.w600,
                    color: isWeekend
                        ? const Color(0xFFE07070).withOpacity(0.8)
                        : labelColor,
                  ),
                ),
              ),
            );
          }).toList(),
        ),
        const SizedBox(height: 8),

        // Day cells
        ...List.generate(cells.length ~/ 7, (row) {
          final rowDays = cells.sublist(row * 7, row * 7 + 7);
          // Find consecutive selected range in this row
          final selectedIndices = <int>[];
          for (int i = 0; i < rowDays.length; i++) {
            final d = rowDays[i];
            if (d != null && appState.getEventsForDay(_dateKey(d)).isNotEmpty) {
              selectedIndices.add(i);
            }
          }

          return Padding(
            padding: const EdgeInsets.only(bottom: 6),
            child: _CalendarRow(
              days: rowDays,
              selectedDay: selectedDay,
              appState: appState,
              onDayTap: onDayTap,
              isDark: isDark,
            ),
          );
        }),
      ],
    );
  }
}

class _CalendarRow extends StatelessWidget {
  final List<DateTime?> days;
  final DateTime? selectedDay;
  final AppState appState;
  final void Function(DateTime) onDayTap;
  final bool isDark;

  const _CalendarRow({
    required this.days,
    required this.selectedDay,
    required this.appState,
    required this.onDayTap,
    required this.isDark,
  });

  String _dateKey(DateTime d) =>
      '${d.year}-${d.month.toString().padLeft(2, '0')}-${d.day.toString().padLeft(2, '0')}';

  @override
  Widget build(BuildContext context) {
    // Find consecutive event days for pill rendering
    final hasEvent = <bool>[];
    for (final d in days) {
      hasEvent.add(d != null &&
          appState.getEventsForDay(_dateKey(d)).isNotEmpty);
    }

    // Find runs of consecutive event days
    final runStart = <int, int>{}; // index -> run length
    int i = 0;
    while (i < days.length) {
      if (hasEvent[i]) {
        int j = i;
        while (j < days.length && hasEvent[j]) j++;
        for (int k = i; k < j; k++) runStart[k] = j - i;
        i = j;
      } else {
        i++;
      }
    }

    return SizedBox(
      height: 48,
      child: Stack(
        children: [
          // Pill backgrounds for consecutive event days
          ...runStart.entries.map((e) {
            final start = e.key;
            final len = e.value;
            if (len < 2) return const SizedBox.shrink();
            final cellWidth = 1.0 / 7;
            final left = start * cellWidth;
            final events = days[start] != null
                ? appState.getEventsForDay(_dateKey(days[start]!))
                : <EventType>[];
            final pillColor = events.isNotEmpty
                ? events.first.color.withOpacity(0.25)
                : const Color(0xFF5A8FDB).withOpacity(0.18);
            return Positioned.fill(
              child: FractionallySizedBox(
                alignment: Alignment.centerLeft,
                widthFactor: len * cellWidth,
                child: Padding(
                  padding: EdgeInsets.only(
                    left: start == 0 ? 0 : 0,
                    top: 4,
                    bottom: 4,
                  ),
                  child: Container(
                    margin: EdgeInsets.only(
                      left: start == 0 ? 4 : 0,
                      right: (start + len) >= 7 ? 4 : 0,
                    ),
                    decoration: BoxDecoration(
                      color: pillColor,
                      borderRadius: BorderRadius.horizontal(
                        left: start == 0 || !hasEvent[start > 0 ? start - 1 : 0]
                            ? const Radius.circular(24)
                            : Radius.zero,
                        right: (start + len) >= 7 ||
                                !(start + len < days.length &&
                                    hasEvent[start + len])
                            ? const Radius.circular(24)
                            : Radius.zero,
                      ),
                    ),
                  ),
                ),
              ),
            );
          }),

          // Day cells
          Row(
            children: List.generate(days.length, (idx) {
              final day = days[idx];
              if (day == null) return const Expanded(child: SizedBox());

              final key = _dateKey(day);
              final events = appState.getEventsForDay(key);
              final isSelected = selectedDay != null &&
                  day.year == selectedDay!.year &&
                  day.month == selectedDay!.month &&
                  day.day == selectedDay!.day;
              final isToday = day.year == DateTime.now().year &&
                  day.month == DateTime.now().month &&
                  day.day == DateTime.now().day;
              final isWeekend = day.weekday == DateTime.saturday ||
                  day.weekday == DateTime.sunday;
              final hasEvents = events.isNotEmpty;
              final inRun = runStart.containsKey(idx) && runStart[idx]! >= 2;

              Color? textColor;
              Color? bgColor;
              FontWeight fw = FontWeight.w500;

              if (isSelected && !hasEvents) {
                bgColor = const Color(0xFF5A8FDB);
                textColor = Colors.white;
                fw = FontWeight.w700;
              } else if (isToday && !hasEvents) {
                bgColor = const Color(0xFF5A8FDB).withOpacity(0.15);
                textColor = const Color(0xFF5A8FDB);
                fw = FontWeight.w700;
              } else if (hasEvents) {
                final color = events.first.color;
                if (!inRun) {
                  bgColor = color.withOpacity(0.2);
                }
                textColor = isDark ? color.withOpacity(0.9) : color;
                fw = FontWeight.w700;
              } else if (isWeekend) {
                textColor = const Color(0xFFE07070);
              } else {
                textColor = isDark ? Colors.white70 : const Color(0xFF2D3250);
              }

              return Expanded(
                child: GestureDetector(
                  onTap: () => onDayTap(day),
                  child: AnimatedContainer(
                    duration: const Duration(milliseconds: 180),
                    curve: Curves.easeOut,
                    margin: const EdgeInsets.all(2),
                    decoration: BoxDecoration(
                      color: bgColor,
                      borderRadius: BorderRadius.circular(14),
                    ),
                    child: Center(
                      child: Text(
                        '${day.day}',
                        style: TextStyle(
                          fontSize: 15,
                          fontWeight: fw,
                          color: textColor,
                        ),
                      ),
                    ),
                  ),
                ),
              );
            }),
          ),
        ],
      ),
    );
  }
}

// ─── Day Event Summary ────────────────────────────────────────────────────────

class _DayEventSummary extends StatelessWidget {
  final DateTime day;
  final AppState appState;
  final Color cardColor;
  final Color textColor;
  final Color subColor;

  const _DayEventSummary({
    required this.day,
    required this.appState,
    required this.cardColor,
    required this.textColor,
    required this.subColor,
  });

  String _dateKey(DateTime d) =>
      '${d.year}-${d.month.toString().padLeft(2, '0')}-${d.day.toString().padLeft(2, '0')}';

  @override
  Widget build(BuildContext context) {
    final events = appState.getEventsForDay(_dateKey(day));
    final ru = appState.isRu;

    final dayLabel = ru
        ? '${day.day} ${_ruMonth(day.month)}'
        : '${_enMonth(day.month)} ${day.day}';

    return Padding(
      padding: const EdgeInsets.symmetric(horizontal: 16),
      child: AnimatedContainer(
        duration: const Duration(milliseconds: 250),
        decoration: BoxDecoration(
          color: cardColor,
          borderRadius: BorderRadius.circular(20),
          boxShadow: [
            BoxShadow(
              color: Colors.black.withOpacity(0.06),
              blurRadius: 12,
              offset: const Offset(0, 2),
            )
          ],
        ),
        padding: const EdgeInsets.all(16),
        child: Column(
          crossAxisAlignment: CrossAxisAlignment.start,
          children: [
            Text(
              ru ? 'Задачи на $dayLabel' : 'Tasks for $dayLabel',
              style: TextStyle(
                fontSize: 15,
                fontWeight: FontWeight.w600,
                color: textColor,
              ),
            ),
            const SizedBox(height: 10),
            if (events.isEmpty)
              Text(
                ru ? 'Нет событий. Нажмите на дату, чтобы добавить.'
                    : 'No events. Tap a date to add.',
                style: TextStyle(fontSize: 13, color: subColor),
              )
            else
              Wrap(
                spacing: 8,
                runSpacing: 8,
                children: events.map((e) {
                  return Container(
                    padding: const EdgeInsets.symmetric(
                        horizontal: 12, vertical: 6),
                    decoration: BoxDecoration(
                      color: e.color.withOpacity(0.15),
                      borderRadius: BorderRadius.circular(20),
                      border: Border.all(
                          color: e.color.withOpacity(0.4), width: 1),
                    ),
                    child: Row(
                      mainAxisSize: MainAxisSize.min,
                      children: [
                        Text(e.emoji, style: const TextStyle(fontSize: 14)),
                        const SizedBox(width: 6),
                        Text(
                          e.label(ru),
                          style: TextStyle(
                            fontSize: 13,
                            fontWeight: FontWeight.w600,
                            color: e.color,
                          ),
                        ),
                      ],
                    ),
                  );
                }).toList(),
              ),
          ],
        ),
      ),
    );
  }

  String _ruMonth(int m) {
    const names = [
      '', 'января', 'февраля', 'марта', 'апреля', 'мая', 'июня',
      'июля', 'августа', 'сентября', 'октября', 'ноября', 'декабря'
    ];
    return names[m];
  }

  String _enMonth(int m) {
    const names = [
      '', 'Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun',
      'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'
    ];
    return names[m];
  }
}

// ─── Event Picker Sheet ────────────────────────────────────────────────────

class _EventPickerSheet extends StatefulWidget {
  final DateTime day;
  final AppState appState;
  final void Function(List<EventType>) onSave;

  const _EventPickerSheet({
    required this.day,
    required this.appState,
    required this.onSave,
  });

  @override
  State<_EventPickerSheet> createState() => _EventPickerSheetState();
}

class _EventPickerSheetState extends State<_EventPickerSheet> {
  late Set<EventType> _selected;

  String _dateKey(DateTime d) =>
      '${d.year}-${d.month.toString().padLeft(2, '0')}-${d.day.toString().padLeft(2, '0')}';

  @override
  void initState() {
    super.initState();
    _selected = widget.appState
        .getEventsForDay(_dateKey(widget.day))
        .toSet();
  }

  @override
  Widget build(BuildContext context) {
    final ru = widget.appState.isRu;
    final isDark = widget.appState.isDark;
    final bg = isDark ? const Color(0xFF252840) : Colors.white;
    final textColor =
        isDark ? Colors.white : const Color(0xFF1A1D2E);

    return Container(
      decoration: BoxDecoration(
        color: bg,
        borderRadius: const BorderRadius.vertical(top: Radius.circular(28)),
      ),
      padding: const EdgeInsets.fromLTRB(20, 16, 20, 32),
      child: Column(
        mainAxisSize: MainAxisSize.min,
        children: [
          Container(
            width: 40,
            height: 4,
            decoration: BoxDecoration(
              color: Colors.grey.withOpacity(0.3),
              borderRadius: BorderRadius.circular(2),
            ),
          ),
          const SizedBox(height: 16),
          Text(
            ru ? 'Выберите события' : 'Select events',
            style: TextStyle(
              fontSize: 18,
              fontWeight: FontWeight.w700,
              color: textColor,
            ),
          ),
          const SizedBox(height: 16),
          GridView.count(
            crossAxisCount: 2,
            shrinkWrap: true,
            physics: const NeverScrollableScrollPhysics(),
            mainAxisSpacing: 10,
            crossAxisSpacing: 10,
            childAspectRatio: 3.2,
            children: EventType.values.map((type) {
              final sel = _selected.contains(type);
              return GestureDetector(
                onTap: () {
                  setState(() {
                    if (sel) {
                      _selected.remove(type);
                    } else {
                      _selected.add(type);
                    }
                  });
                },
                child: AnimatedContainer(
                  duration: const Duration(milliseconds: 180),
                  decoration: BoxDecoration(
                    color: sel
                        ? type.color.withOpacity(0.2)
                        : (isDark
                            ? Colors.white.withOpacity(0.06)
                            : Colors.grey.withOpacity(0.08)),
                    borderRadius: BorderRadius.circular(14),
                    border: Border.all(
                      color: sel ? type.color : Colors.transparent,
                      width: 1.5,
                    ),
                  ),
                  padding: const EdgeInsets.symmetric(horizontal: 12),
                  child: Row(
                    children: [
                      Text(type.emoji,
                          style: const TextStyle(fontSize: 18)),
                      const SizedBox(width: 8),
                      Expanded(
                        child: Text(
                          type.label(ru),
                          style: TextStyle(
                            fontSize: 13,
                            fontWeight: FontWeight.w600,
                            color: sel
                                ? type.color
                                : (isDark
                                    ? Colors.white70
                                    : const Color(0xFF4A4E69)),
                          ),
                          overflow: TextOverflow.ellipsis,
                        ),
                      ),
                    ],
                  ),
                ),
              );
            }).toList(),
          ),
          const SizedBox(height: 20),
          Row(
            children: [
              Expanded(
                child: OutlinedButton(
                  onPressed: () => Navigator.pop(context),
                  style: OutlinedButton.styleFrom(
                    padding: const EdgeInsets.symmetric(vertical: 14),
                    shape: RoundedRectangleBorder(
                        borderRadius: BorderRadius.circular(14)),
                    side: BorderSide(
                        color: Colors.grey.withOpacity(0.3)),
                  ),
                  child: Text(
                    ru ? 'Отмена' : 'Cancel',
                    style: TextStyle(color: textColor.withOpacity(0.6)),
                  ),
                ),
              ),
              const SizedBox(width: 12),
              Expanded(
                child: ElevatedButton(
                  onPressed: () {
                    widget.onSave(_selected.toList());
                    Navigator.pop(context);
                  },
                  style: ElevatedButton.styleFrom(
                    backgroundColor: const Color(0xFF5A8FDB),
                    padding: const EdgeInsets.symmetric(vertical: 14),
                    shape: RoundedRectangleBorder(
                        borderRadius: BorderRadius.circular(14)),
                  ),
                  child: Text(
                    ru ? 'Сохранить' : 'Save',
                    style: const TextStyle(
                        color: Colors.white, fontWeight: FontWeight.w700),
                  ),
                ),
              ),
            ],
          ),
        ],
      ),
    );
  }
}

// ─── Menu Button ─────────────────────────────────────────────────────────────

class _MenuButton extends StatelessWidget {
  final AppState appState;
  const _MenuButton({required this.appState});

  @override
  Widget build(BuildContext context) {
    final isDark = appState.isDark;
    final ru = appState.isRu;
    return PopupMenuButton<String>(
      icon: Icon(
        Icons.more_vert_rounded,
        color: isDark ? Colors.white70 : const Color(0xFF4A4E69),
      ),
      shape: RoundedRectangleBorder(borderRadius: BorderRadius.circular(16)),
      color: isDark ? const Color(0xFF2E3250) : Colors.white,
      elevation: 8,
      onSelected: (value) async {
        if (value == 'theme') {
          await appState.toggleTheme();
        } else if (value == 'lang') {
          await appState.toggleLanguage();
        }
      },
      itemBuilder: (_) => [
        PopupMenuItem(
          value: 'theme',
          child: Row(
            children: [
              Icon(
                isDark ? Icons.light_mode_rounded : Icons.dark_mode_rounded,
                color: isDark ? Colors.amber : const Color(0xFF5A8FDB),
                size: 20,
              ),
              const SizedBox(width: 10),
              Text(
                isDark
                    ? (ru ? 'Светлая тема' : 'Light theme')
                    : (ru ? 'Тёмная тема' : 'Dark theme'),
                style: TextStyle(
                  color: isDark ? Colors.white : const Color(0xFF1A1D2E),
                  fontWeight: FontWeight.w500,
                ),
              ),
            ],
          ),
        ),
        PopupMenuItem(
          value: 'lang',
          child: Row(
            children: [
              Text(
                ru ? '🇬🇧' : '🇷🇺',
                style: const TextStyle(fontSize: 18),
              ),
              const SizedBox(width: 10),
              Text(
                ru ? 'English' : 'Русский',
                style: TextStyle(
                  color: isDark ? Colors.white : const Color(0xFF1A1D2E),
                  fontWeight: FontWeight.w500,
                ),
              ),
            ],
          ),
        ),
      ],
    );
  }
}

// ─── Nav Arrow ───────────────────────────────────────────────────────────────

class _NavArrow extends StatelessWidget {
  final IconData icon;
  final VoidCallback onTap;
  final bool isDark;

  const _NavArrow(
      {required this.icon, required this.onTap, required this.isDark});

  @override
  Widget build(BuildContext context) {
    return GestureDetector(
      onTap: onTap,
      child: Container(
        width: 34,
        height: 34,
        decoration: BoxDecoration(
          color: isDark
              ? Colors.white.withOpacity(0.08)
              : Colors.black.withOpacity(0.05),
          borderRadius: BorderRadius.circular(10),
        ),
        child: Icon(
          icon,
          size: 20,
          color: isDark ? Colors.white70 : const Color(0xFF4A4E69),
        ),
      ),
    );
  }
}
